# ─────────────────────────────────────────────────
# OpenAI API （必須・主モデル）
# ─────────────────────────────────────────────────
# Phase 1 / Phase 2 ともにOpenAIファインチューニング済みモデルを使う方針。
# ベースモデルの想定：
#   - Phase 1 FAQ Bot          : gpt-4o-mini
#   - Phase 2 メソッド Bot     : gpt-4o
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 使用モデル（省略時 gpt-4o-mini）
# ファインチューン完了後は返ってきたモデルIDに差し替えてください。
# 例: CHAT_MODEL=ft:gpt-4o-mini-2024-07-18:enlight-academy:faq:ABC123
CHAT_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────
# Anthropic Claude API （任意・併用検証用）
# ─────────────────────────────────────────────────
# 「先生らしさ」の精度比較・将来の併用判断のために PoC 期間中に併走する場合のみ設定。
# 現状の chat.py は OpenAI 単体実装。Claude を呼ぶロジックは未実装。
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────
# Slack Incoming Webhook （任意）
# ─────────────────────────────────────────────────
# 未設定でもアプリは動くが、通知のみモードの確認やエスカレーションが Slack に届かない。
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/XXX/XXXXXX

# ─────────────────────────────────────────────────
# 動作モード
# ─────────────────────────────────────────────────
# パイロット運用フラグ（true=Slackに回答案を通知 / false=直接回答のみ）
PILOT_MODE=true
